<Page x:Class="Victorina.Pages.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Старт"
      Background="Aqua">

    <Page.Resources>
        <Style x:Key="StartButton" TargetType="Button">
            <Setter Property="FontFamily" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="AliceBlue"/>
            <Setter Property="Background" Value="DarkSlateBlue"/>
            <Setter Property="Padding" Value="30,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="25" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3C2F8C"/>
                </Trigger>

                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="AliceBlue"/>
                    <Setter Property="Foreground" Value="DarkSlateBlue"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="🧠"
                       FontSize="80"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
            
            <TextBlock Text="ВИКТОРИНА"
                       FontSize="42"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="Black"/>

            <TextBlock Text="Проверь свои знания по C#"
                       FontSize="16"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,30"/>

            <Button Content="Начать" HorizontalAlignment="Center" Style="{StaticResource StartButton}" Click="Start_Click"/>
        </StackPanel>
    </Grid>
</Page>
