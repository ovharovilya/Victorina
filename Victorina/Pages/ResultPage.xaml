<Page x:Class="Victorina.Pages.ResultPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Результат"
      Background="Black">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="EmojiText" FontSize="80" HorizontalAlignment="Center" Foreground="White" Margin="0,0,0,10"/>
            <TextBlock Text="Результат: " FontSize="36" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock x:Name="ScoreText" FontSize="22" Foreground="#CCCCCC" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock x:Name="CommentText" FontSize="16" Foreground="#888888" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <Button Content="Пройти еще раз" HorizontalAlignment="Center" Click="restart_click"/>
        </StackPanel>
    </Grid>
</Page>
